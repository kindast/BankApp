<Window x:Class="BankApp.Views.WndTransactions"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BankApp.Views"
        mc:Ignorable="d"
        Title="История операций" Height="450" Width="600" Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
            <TextBlock Text="Последние операции" Style="{StaticResource BaseTextBlock}" Margin="10"/>
            <ListBox x:Name="lbTransactions" SelectionChanged="lbTransactions_SelectionChanged"/>
        </StackPanel>
        <StackPanel Grid.Column="1">
            <TextBlock x:Name="tbTextTransaction"/>
            <Button Content="Сохранить в файл" Style="{StaticResource BaseButton}" Width="200"/>
        </StackPanel>
    </Grid>
</Window>
