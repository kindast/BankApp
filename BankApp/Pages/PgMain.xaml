        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
            <StackPanel>
                <TextBlock x:Name="tbMyCards" Text="Мои счета" HorizontalAlignment="Center" Style="{StaticResource BaseTextBlock}"/>
                <Button  Grid.Column="1" Content="История операций" Style="{StaticResource BaseButton}" Click="OpenTransactions" Margin="5"/>
                <StackPanel x:Name="spCards"/>

                <TextBlock Text="Операции" HorizontalAlignment="Center" Style="{StaticResource BaseTextBlock}"/>
                <ListBox x:Name="lbOperations" SelectionChanged="ListBox_SelectionChanged" Style="{StaticResource BaseListBox}">
                    <ListBoxItem Content="Открыть новую карту" FontSize="15"/>
                    <ListBoxItem Content="Закрыть карту" FontSize="15"/>
                    <ListBoxItem Content="Пополнить карту" FontSize="15"/>
                    <ListBoxItem Content="Снять деньги с карты" FontSize="15"/>
                    <ListBoxItem Content="Перевести деньги по номеру карты" FontSize="15"/>
                </ListBox>

                <TextBlock x:Name="tbCardNameLabel" Text="Название карты" Style="{StaticResource BaseTextBlock}" Margin="5,0,0,3"/>
                <TextBox x:Name="tbCardName" Style="{StaticResource BaseTextBox}" Margin="5,0,5,10" MaxLength="20"/>
                <Button x:Name="btnOpenCard" Content="Открыть новую карту" Style="{StaticResource BaseButton}" 
                            Click="OpenNewCard" Margin="5,0,5,0" FontWeight="Regular" Cursor="Hand"/>
                <TextBlock x:Name="tbCardSelectionLabel" Text="Карта" Style="{StaticResource BaseTextBlock}" Margin="5,0,0,3"/>
                <ComboBox x:Name="cbCardSelection" Margin="5,0,5,10"/>
                <Button x:Name="btnDeleteCard" Content="Закрыть карту" Style="{StaticResource BaseButton}" 
                            Click="DeleteCard" Margin="5,0,5,0" FontWeight="Regular"/>
                <TextBlock x:Name="tbMoneyLabel" Text="Сумма" Style="{StaticResource BaseTextBlock}" Margin="5,0,0,3"/>
                <TextBox x:Name="tbMoney" Style="{StaticResource BaseTextBox}" PreviewKeyDown="cbMoney_PreviewKeyDown" 
                             PreviewTextInput="cbMoney_PreviewTextInput" Margin="5,0,5,10" MaxLength="20"/>
                <TextBlock x:Name="tbCardNumberLabel" Text="Номер карты" Style="{StaticResource BaseTextBlock}" Margin="5,0,0,3"/>
                <TextBox x:Name="tbCardNumber" Style="{StaticResource BaseTextBox}" PreviewTextInput="tbCardNumber_PreviewTextInput" 
                             PreviewKeyDown="tbCardNumber_PreviewKeyDown"  MaxLength="16" Margin="5,0,5,10"/>
                <Button x:Name="btnTransfer" Content="Перевести" Style="{StaticResource BaseButton}" 
                            Click="Transfer" Margin="5,0,5,0" FontWeight="Regular"/>
                <Button x:Name="btnAddMoney" Content="Пополнить" Style="{StaticResource BaseButton}" FontWeight="Regular"
                            Click="AddMoney" Cursor="Hand" Margin="5,0,5,0"/>
                <Button x:Name="btnWithdrawMoney" Content="Снять" Style="{StaticResource BaseButton}" FontWeight="Regular"
                            Click="WithdrawMoney" Cursor="Hand" Margin="5,0,5,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
