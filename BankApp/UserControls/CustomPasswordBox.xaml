        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="tbText" Style="{StaticResource BaseTextBox}" Panel.ZIndex="0"/>
        <PasswordBox x:Name="tbPassword" Style="{StaticResource BasePasswordBox}" Panel.ZIndex="1" 
                     PasswordChar="*"/>
